#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")"

if [[ ! -d .venv ]]; then
  echo "Creating virtual environment..."
  python3 -m venv .venv
fi

if ! .venv/bin/python -c "import requests" >/dev/null 2>&1; then
  echo "Installing dependencies..."
  .venv/bin/pip install -q -r requirements.txt
fi

if [[ "${1:-}" == "ui" ]]; then
  shift
  exec .venv/bin/python backend/crawl_site.py ui "$@"
fi

exec .venv/bin/python backend/crawl_site.py "$@"
